# ============================================================================
# Q Meet — environment variables
# Copy to `.env.local` and fill in real values. NEVER commit secrets.
# ============================================================================

# --- Application environment ----------------------------------------------------
# development | production — drives media provider rules and mock availability.
APP_ENV="development"
NODE_ENV="development"

# --- Media provider -------------------------------------------------------------
# mock    → local development fallback (no real devices)
# livekit → real LiveKit SFU (required in production)
MEDIA_PROVIDER="mock"

# Allow mock media in production only when explicitly set (default: false in prod).
ENABLE_MOCK_MEDIA="true"

# --- LiveKit (required in production) -------------------------------------------
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# --- Database -------------------------------------------------------------------
DATABASE_URL="postgresql://qimam_app:CHANGE_ME@localhost:5432/qimam_meet?schema=public"

# --- Application auth (JWT) -----------------------------------------------------
AUTH_ACCESS_TOKEN_SECRET="CHANGE_ME"
AUTH_REFRESH_TOKEN_SECRET="CHANGE_ME"
INVITE_LINK_SECRET="CHANGE_ME"

# --- Recordings storage (LiveKit Egress → S3/MinIO) -----------------------------
RECORDINGS_S3_ENDPOINT="https://minio.example.internal"
RECORDINGS_S3_BUCKET="qimam-recordings"
RECORDINGS_S3_ACCESS_KEY="CHANGE_ME"
RECORDINGS_S3_SECRET_KEY="CHANGE_ME"
RECORDINGS_S3_REGION="us-east-1"

# --- App ------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo seed users for local development only (disable in production).
ENABLE_DEMO_USERS="true"

# ============================================================================
# Production recommendations (Railway / production):
#   APP_ENV=production
#   NODE_ENV=production
#   MEDIA_PROVIDER=livekit
#   ENABLE_MOCK_MEDIA=false
#   ENABLE_DEMO_USERS=false
#   DATABASE_URL=<Railway PostgreSQL connection string>
#   NEXT_PUBLIC_APP_URL=<your public Railway domain, e.g. https://qmeet.up.railway.app>
#   LIVEKIT_API_SECRET must never be exposed to the browser
#   .env.local must not be committed
# ============================================================================
