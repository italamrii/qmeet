# ============================================================================
# QIMAM Meet — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env` (see .gitignore).
# Rotation practice: see README.md §Security Setup.
# ============================================================================

# --- Database -----------------------------------------------------------------
# PostgreSQL connection string used by Prisma. Use a dedicated, least-privilege
# DB user (no superuser). TLS strongly recommended: append `?sslmode=require`.
DATABASE_URL="postgresql://qimam_app:CHANGE_ME@localhost:5432/qimam_meet?schema=public"

# --- LiveKit (self-hosted SFU) --------------------------------------------------
# WSS URL of the LiveKit server. MUST be wss:// (TLS) — no ws:// plaintext fallback.
LIVEKIT_URL="wss://livekit.example.internal"
# LiveKit API key ID. Server-side only — never exposed to the client bundle.
LIVEKIT_API_KEY="CHANGE_ME"
# LiveKit API secret. Used to mint short-TTL access tokens server-side only.
LIVEKIT_API_SECRET="CHANGE_ME"

# --- Application auth (JWT) -----------------------------------------------------
# Secret for signing 15-minute access tokens. Generate: `openssl rand -base64 48`.
AUTH_ACCESS_TOKEN_SECRET="CHANGE_ME"
# Separate secret for refresh tokens (rotation) — must differ from the access secret.
AUTH_REFRESH_TOKEN_SECRET="CHANGE_ME"
# Secret for signing time-limited room invite links (HMAC). Rotate independently.
INVITE_LINK_SECRET="CHANGE_ME"

# --- Recordings storage (LiveKit Egress → S3/MinIO) ------------------------------
# S3-compatible endpoint for encrypted-at-rest recording storage (SSE enabled).
RECORDINGS_S3_ENDPOINT="https://minio.example.internal"
RECORDINGS_S3_BUCKET="qimam-recordings"
RECORDINGS_S3_ACCESS_KEY="CHANGE_ME"
RECORDINGS_S3_SECRET_KEY="CHANGE_ME"
RECORDINGS_S3_REGION="us-east-1"

# --- App ------------------------------------------------------------------------
# Public origin of this app (used for signed invite links + CORS scoping).
NEXT_PUBLIC_APP_URL="https://meet.example.internal"
